rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------- USERS ----------------
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // ---------------- DM CHATS (Unified: dm + group) ----------------
    match /dmChats/{chatId} {

      function authed() {
        return request.auth != null;
      }

      function chatDoc() {
        return get(/databases/$(database)/documents/dmChats/$(chatId));
      }

      function parentMembers() {
        return chatDoc().data.members;
      }

      function isMember() {
        return authed() && (request.auth.uid in resource.data.members);
      }

      function isMemberViaGet() {
        return authed() && (request.auth.uid in parentMembers());
      }

      function isMemberInNew() {
        return authed() && (request.auth.uid in request.resource.data.members);
      }

      function myMemberDoc() {
        return get(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid));
      }

      function myRole() {
        return myMemberDoc().data.role;
      }

      function isAdminOrOwner() {
        return authed() && (myRole() == 'owner' || myRole() == 'admin');
      }

      function ownerId() {
        return chatDoc().data.ownerId;
      }

      // Read chat only if user is a member
      allow read: if isMember();

      // Create chat only if creator is included in members list
      allow create: if isMemberInNew();

      // Update chat is allowed for any existing member
      // (keeps lastMessage/lastTimestamp updates working)
      allow update: if isMember();

      // ---------------- MEMBERS ----------------
      match /members/{memberId} {

        // Existing member can read members list
        allow read: if isMemberViaGet();

        // Existing member can create member docs (used when adding members)
        allow create: if isMemberViaGet()
          && request.resource.data.userId == memberId;

        // Existing member can update member docs (mute, role later, etc)
        allow update: if isMemberViaGet()
          && request.resource.data.userId == memberId;

        // Allow admin/owner to delete member docs, but never the owner
        allow delete: if isMemberViaGet()
          && isAdminOrOwner()
          && memberId != ownerId();
      }

      // ---------------- PENDING MEMBERS (approval flow) ----------------
      match /pendingMembers/{pendingUid} {
        allow read: if isMemberViaGet();

        // Existing member can request add (your code sets doc(uid))
        allow create: if isMemberViaGet()
          && request.resource.data.userId == pendingUid;

        // Keep updates/deletes locked unless you later add admin logic
        allow update, delete: if false;
      }

      // ---------------- MESSAGES ----------------
      match /messages/{messageId} {

        function isParentMember() {
          return isMemberViaGet();
        }

        function changedKeysOnly(keys) {
          return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
        }

        function senderImmutableOk() {
          return request.resource.data.senderId == resource.data.senderId
            && request.resource.data.chatId == resource.data.chatId;
        }

        // Read message
        allow read: if isParentMember();

        // Create message (sender must be authed user)
        allow create: if isParentMember()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.chatId == chatId;

        // Update message
        // Sender can update own message (needed for media upload progress/retry fields).
        // Non-senders are restricted to reaction/delivery/read/delete-for-me fields only.
        allow update: if isParentMember() && (
          (request.auth.uid == resource.data.senderId && senderImmutableOk())
          || changedKeysOnly([
              'reactions',
              'userReactions',
              'status',
              'isSeen',
              'seenAt',
              'deliveredAt',
              'deletedFor',
              'deleteFor'
            ])
        );

        // Delete message: only sender
        allow delete: if isParentMember()
          && request.auth.uid == resource.data.senderId;
      }

      // ---------------- AUDIT LOGS ----------------
      match /auditLogs/{logId} {
        // Members can read audit logs
        allow read: if isMemberViaGet();

        // Only admin/owner can write moderation history
        allow create: if isMemberViaGet()
          && (
            get(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
          )
          && request.resource.data.performedBy == request.auth.uid;

        // Audit logs cannot be updated or deleted
        allow update, delete: if false;
      }

    }

    // ---------------- DENY EVERYTHING ELSE ----------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
