rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------- USERS ----------------
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;

      // Per-user UI state for chats (must NOT affect dmChats/messages)
      // Path: users/{uid}/chatSettings/{chatId}
      match /chatSettings/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ---------------- DM CHATS (Unified: dm + group) ----------------
    match /dmChats/{chatId} {

      function authed() {
        return request.auth != null;
      }

      function chatDoc() {
        return get(/databases/$(database)/documents/dmChats/$(chatId));
      }

      function parentMembers() {
        return chatDoc().data.members;
      }

      // Query-stable membership check for dmChats list/get:
      // ONLY uses resource.data.members.
      function isMember() {
        return authed() && (request.auth.uid in resource.data.members);
      }

      // Subcollection membership check using parent members array.
      function isMemberViaGet() {
        return authed() && (request.auth.uid in parentMembers());
      }

      function isMemberInNew() {
        return authed() && (request.auth.uid in request.resource.data.members);
      }

      function myMemberDoc() {
        return get(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid));
      }

      function myBannedUntil() {
        return myMemberDoc().data.bannedUntil;
      }

      function myMutedUntil() {
        return myMemberDoc().data.mutedUntil;
      }

      function myRole() {
        return myMemberDoc().data.role;
      }

      function isAdminOrOwner() {
        return authed() && (myRole() == 'owner' || myRole() == 'admin');
      }

      function ownerId() {
        return chatDoc().data.ownerId;
      }

      // Read chat only if user is a member (RESOURCE MEMBERS ONLY)
      allow read: if isMember();

      // Create chat only if creator is included in members list
      allow create: if isMemberInNew();

      // Update chat is allowed for any existing member
      // (keeps lastMessage/lastTimestamp updates working)
      allow update: if isMember();

      // ---------------- MEMBERS ----------------
      match /members/{memberId} {
        allow read: if isMemberViaGet();
        allow create: if request.auth != null
          && request.resource.data.userId == memberId
          && (
            // Owner bootstrap case
            get(/databases/$(database)/documents/dmChats/$(chatId)).data.ownerId == request.auth.uid
            ||
            // Admin/owner can add members
            (
              exists(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid))
              && get(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
            )
          );
        allow update: if isMemberViaGet()
          && request.resource.data.userId == memberId;
        allow delete: if isMemberViaGet()
          && isAdminOrOwner()
          && memberId != ownerId();
      }

      // ---------------- PENDING MEMBERS (approval flow) ----------------
      match /pendingMembers/{pendingUid} {
        allow read: if isMemberViaGet();
        allow create: if isMemberViaGet()
          && request.resource.data.userId == pendingUid;
        allow update, delete: if false;
      }

      // ---------------- MESSAGES ----------------
      match /messages/{messageId} {

        function isParentMember() {
          return isMemberViaGet();
        }

        function changedKeysOnly(keys) {
          return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
        }

        function senderImmutableOk() {
          return request.resource.data.senderId == resource.data.senderId
            && request.resource.data.chatId == resource.data.chatId;
        }

        function memberModerationOk() {
          let m = get(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid));
          return (
            !('mutedUntil' in m.data)
            || m.data.mutedUntil == null
            || m.data.mutedUntil < request.time
          )
          && (
            !('bannedUntil' in m.data)
            || m.data.bannedUntil == null
            || m.data.bannedUntil < request.time
          );
        }

        allow read: if isMemberViaGet();

        allow create: if isParentMember()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.chatId == chatId
          && request.resource.data.createdAt is timestamp
          && (
            chatDoc().data.type != 'group'
            ||
            !exists(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid))
            ||
            memberModerationOk()
          );

        allow update: if isParentMember() && (
          (request.auth.uid == resource.data.senderId && senderImmutableOk())
          || changedKeysOnly([
              'poll',
              'reactions',
              'userReactions',
              'status',
              'isSeen',
              'seenAt',
              'deliveredAt',
              'deletedFor',
              'deleteFor'
            ])
        );

        allow delete: if isParentMember()
          && request.auth.uid == resource.data.senderId;
      }

      // ---------------- AUDIT LOGS ----------------
      match /auditLogs/{logId} {
        allow read: if isMemberViaGet();
        allow create: if isMemberViaGet()
          && (
            get(/databases/$(database)/documents/dmChats/$(chatId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
          )
          && request.resource.data.performedBy == request.auth.uid;
        allow update, delete: if false;
      }

      // ---------------- MODERATION LOGS (Dashboard v2) ----------------
      match /moderationLogs/{logId} {
        allow read: if isMemberViaGet() && isAdminOrOwner();
        allow create: if isMemberViaGet()
          && isAdminOrOwner()
          && request.resource.data.performedBy == request.auth.uid;
        allow update, delete: if false;
      }

    }

    // ---------------- VOICE/VIDEO CALLS ----------------
    match /calls/{callId} {
      
      function authed() {
        return request.auth != null;
      }
      
      function isCallerOrReceiver() {
        return authed() && (
          resource.data.callerId == request.auth.uid 
          || resource.data.receiverId == request.auth.uid
        );
      }
      
      function isCallerInNew() {
        return authed() && request.resource.data.callerId == request.auth.uid;
      }
      
      function callerIdImmutable() {
        return request.resource.data.callerId == resource.data.callerId;
      }
      
      function receiverIdImmutable() {
        return request.resource.data.receiverId == resource.data.receiverId;
      }
      
      // Allow users to create calls where they are the caller
      // Prevents impersonation and self-calling
      allow create: if authed() 
        && isCallerInNew()
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.type in ['voice', 'video']
        && request.resource.data.status in ['calling', 'ringing']
        && request.resource.data.createdAt is timestamp;
      
      // Allow caller and receiver to read the call
      allow read: if isCallerOrReceiver();
      
      // Allow caller and receiver to update call status
      // Ensure caller and receiver IDs cannot be changed
      allow update: if isCallerOrReceiver()
        && callerIdImmutable()
        && receiverIdImmutable()
        && request.resource.data.type == resource.data.type;
      
      // Prevent deletion to maintain call history/audit trail
      allow delete: if false;
    }

    // ---------------- CALL LOGS (PERMANENT HISTORY) ----------------
    match /callLogs/{logId} {
      
      function authed() {
        return request.auth != null;
      }
      
      function isCallerOrReceiver() {
        return authed() && (
          resource.data.callerId == request.auth.uid 
          || resource.data.receiverId == request.auth.uid
        );
      }
      
      function isCallerOrReceiverInNew() {
        return authed() && (
          request.resource.data.callerId == request.auth.uid 
          || request.resource.data.receiverId == request.auth.uid
        );
      }
      
      // Allow creating call logs if user is either caller or receiver
      allow create: if isCallerOrReceiverInNew()
        && request.resource.data.type in ['voice', 'video']
        && request.resource.data.status in ['missed', 'completed', 'declined', 'cancelled', 'failed']
        && request.resource.data.startedAt is timestamp;
      
      // Allow caller and receiver to read their call logs
      allow read: if isCallerOrReceiver();
      
      // Allow updates only by participants (for duration updates, etc.)
      allow update: if isCallerOrReceiver();
      
      // Allow deletion only by participants (user wants to delete their history)
      allow delete: if isCallerOrReceiver();
    }

    // ---------------- GROUP CALL ROOMS (Simple orchestrated 1-to-1 calls) ----------------
    match /groupCallRooms/{roomId} {
      
      function authed() {
        return request.auth != null;
      }
      
      function isHost() {
        return authed() && request.resource.data.hostId == request.auth.uid;
      }
      
      function isParticipant() {
        return authed() && request.auth.uid in resource.data.participants;
      }
      
      function isGroupMember(groupId) {
        return authed() 
          && exists(/databases/$(database)/documents/dmChats/$(groupId))
          && (request.auth.uid in get(/databases/$(database)/documents/dmChats/$(groupId)).data.members);
      }
      
      function respectsParticipantLimit() {
        return request.resource.data.participants.size() <= 8;
      }
      
      // Allow creating rooms if user is host and group member
      allow create: if isHost()
        && isGroupMember(request.resource.data.groupId)
        && request.resource.data.status == 'active'
        && request.resource.data.participants is list;
      
      // Allow reading if user is participant or group member
      allow read: if isParticipant() || isGroupMember(resource.data.groupId);
      
      // Allow updates if user is participant (for joining/leaving)
      // Enforce 8-participant limit
      allow update: if (isParticipant() || isGroupMember(resource.data.groupId))
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.hostId == resource.data.hostId
        && respectsParticipantLimit();
      
      // Prevent deletion
      allow delete: if false;
    }

    // ---------------- GROUP CALLS (PHASE 1.1: Room Management) ----------------
    match /groupCalls/{callId} {
      
      function authed() {
        return request.auth != null;
      }
      
      function isInitiator() {
        return authed() && request.resource.data.initiatorId == request.auth.uid;
      }
      
      function isInitiatorExisting() {
        return authed() && resource.data.initiatorId == request.auth.uid;
      }
      
      function isInvited() {
        return authed() && request.auth.uid in resource.data.invitedParticipants;
      }
      
      function isJoined() {
        return authed() && request.auth.uid in resource.data.joinedParticipants;
      }
      
      function isGroupMember(groupId) {
        return authed() 
          && exists(/databases/$(database)/documents/dmChats/$(groupId))
          && (request.auth.uid in get(/databases/$(database)/documents/dmChats/$(groupId)).data.members);
      }
      
      function respectsParticipantLimit() {
        return request.resource.data.joinedParticipants.size() <= 8;
      }
      
      function immutableFields() {
        return request.resource.data.groupId == resource.data.groupId
          && request.resource.data.initiatorId == resource.data.initiatorId
          && request.resource.data.type == resource.data.type;
      }
      
      // Allow creating group calls if user is initiator and group member
      allow create: if isInitiator()
        && isGroupMember(request.resource.data.groupId)
        && request.resource.data.status in ['ringing', 'active']
        && request.resource.data.type == 'group_audio'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.invitedParticipants is list
        && request.resource.data.joinedParticipants is list
        && request.resource.data.declinedParticipants is list
        && request.resource.data.leftParticipants is list;
      
      // Allow reading if user is group member
      allow read: if isGroupMember(resource.data.groupId);
      
      // Allow updates if user is group member (for joining/leaving/declining)
      // Enforce immutable fields and participant limit
      allow update: if isGroupMember(resource.data.groupId)
        && immutableFields()
        && respectsParticipantLimit();
      
      // Prevent deletion (keep history)
      allow delete: if false;
    }

    // ---------------- GROUP CALL INVITATIONS (PHASE 1.1: Reliable Delivery) ----------------
    match /groupCallInvitations/{invitationId} {
      
      function authed() {
        return request.auth != null;
      }
      
      function isInviter() {
        return authed() && request.resource.data.inviterId == request.auth.uid;
      }
      
      function isTarget() {
        return authed() && resource.data.targetUserId == request.auth.uid;
      }
      
      function isTargetInNew() {
        return authed() && request.resource.data.targetUserId == request.auth.uid;
      }
      
      // Allow creating invitations if user is the inviter
      allow create: if isInviter()
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp;
      
      // Allow reading if user is target
      allow read: if isTarget() || isInviter();
      
      // Allow updates only by target (accepting/declining)
      allow update: if isTarget()
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.inviterId == resource.data.inviterId
        && request.resource.data.targetUserId == resource.data.targetUserId
        && request.resource.data.callId == resource.data.callId;
      
      // Allow deletion by system (expired invitations cleanup)
      allow delete: if false;
    }

    // ---------------- DENY EVERYTHING ELSE ----------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
